#!/usr/bin/env bash

set -euo pipefail

declare -a PIDS

cleanup() {
  for pid in "${PIDS[@]}"; do
    if kill -0 "$pid" 2>/dev/null; then
      echo "  Killing $pid"
      kill "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
    fi
  done
}

trap cleanup EXIT

./scripts/guacamole &
PIDS+=($!)

./scripts/chromium &
PIDS+=($!)

./scripts/opencode &
PIDS+=($!)

./scripts/virtual &
PIDS+=($!)

./scripts/tunnel &
PIDS+=($!)

sleep infinity
