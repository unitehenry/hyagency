#!/usr/bin/env bash

set -euo pipefail

declare -a SSH_PIDS

cleanup() {
  for pid in "${SSH_PIDS[@]}"; do
    if kill -0 "$pid" 2>/dev/null; then
        echo "  Killing SSH PID $pid"
        kill "$pid" 2>/dev/null || true
        wait "$pid" 2>/dev/null || true
    fi
  done
}

trap cleanup EXIT

ssh -N -R 8080:127.0.0.1:8080 root@142.93.14.238 &
SSH_PIDS+=($!)

ssh -N -R 4090:127.0.0.1:4090 root@142.93.14.238 &
SSH_PIDS+=($!)

sleep infinity
