#!/usr/bin/env bash

set -euo pipefail

cleanup() {
  pkill -f wayvnc || true
  hyprctl output remove Virtual-1 || true
}

trap cleanup EXIT

hyprctl output create headless Virtual-1

nohup wayvnc 0.0.0.0 5900 "Virtual-1" > wayvnc.out &

sleep 2

CLIENTS=$(hyprctl clients -j | jq -r '.[] | select(.class | test("chromium"; "i")) | .address')

COUNT=$(echo "$CLIENTS" | wc -l)

echo "Found $COUNT Chromium window(s). Moving them to Virtual-1..."

for ADDR in $CLIENTS; do
    echo "→ Moving window $ADDR"
    hyprctl dispatch focuswindow address:"$ADDR" >/dev/null
    hyprctl dispatch movewindow mon:Virtual-1 >/dev/null
    sleep 0.2
done

hyprctl keyword monitor Virtual-1,preferred,auto,1

sleep infinity
